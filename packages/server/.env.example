# Server port
MCP_PORT=3000

# Public base URL — set to your ngrok URL when using Claude Desktop
# e.g. https://your-domain.ngrok-free.app
BASE_URL=http://localhost:3000

# Set to 'false' to disable OAuth (for local testing without auth)
AUTH_ENABLED=true

# Session secret (use a long random string)
SESSION_SECRET=change-me-in-production-use-long-random-string

# JWT signing secret (min 32 chars)
JWT_SECRET=change-me-in-production-min-32-chars!!!

# Google OAuth 2.0 — required when AUTH_ENABLED=true
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://<your-ngrok-domain>/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
